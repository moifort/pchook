{
  "name": "pchook",
  "private": true,
  "scripts": {
    "prepare": "nitro prepare && bun generate",
    "build": "nitro build",
    "dev": "nitro dev --host 0.0.0.0",
    "lint:fix": "bun biome lint --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "generate:schema": "bun server/api-schema/export.ts",
    "generate:swift": "bun scripts/generate-swift-types.ts",
    "generate": "bun run generate:schema && bun run generate:swift"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@types/bun": "1.3.8",
    "@types/lodash-es": "4.17.12",
    "@types/node": "25.2.1",
    "bun-types": "1.3.8",
    "h3": "1.15.5",
    "nitropack": "2.12.4",
    "ts-brand": "0.2.0",
    "typescript": "5.5.4"
  },
  "dependencies": {
    "@apollo/server": "5.4.0",
    "@pothos/core": "4.12.0",
    "@sentry/bun": "10.40.0",
    "consola": "3.4.2",
    "graphql": "16.13.1",
    "lodash-es": "4.17.23",
    "ts-pattern": "5.9.0",
    "zod": "4.3.6"
  }
}
